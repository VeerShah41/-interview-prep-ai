generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique @db.VarChar(255)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  name         String      @db.VarChar(255)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  techStack    Json?       @map("tech_stack")
  interviews   Interview[]

  @@map("users")
}

model Interview {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  targetRole      String       @map("target_role") @db.VarChar(255)
  status          String       @default("in_progress") @db.VarChar(20)
  durationSeconds Int?         @map("duration_seconds")
  startedAt       DateTime     @default(now()) @map("started_at") @db.Timestamptz()
  endedAt         DateTime?    @map("ended_at") @db.Timestamptz()
  overallScore    Decimal?     @map("overall_score") @db.Decimal(3, 1)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  graphState      Json?        @map("graph_state")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[]
  topicScores  TopicScore[]
  feedback     Feedback?

  @@index([userId])
  @@map("interviews")
}

model Message {
  id           String    @id @default(uuid()) @db.Uuid
  interviewId  String    @map("interview_id") @db.Uuid
  role         String    @db.VarChar(20)
  content      String    @db.Text
  nodeType     String?   @map("node_type") @db.VarChar(50)
  sequence     Int
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([interviewId, sequence])
  @@map("messages")
}

model TopicScore {
  id             String   @id @default(uuid()) @db.Uuid
  interviewId    String   @map("interview_id") @db.Uuid
  topic          String   @db.VarChar(100)
  situationScore Decimal? @map("situation_score") @db.Decimal(3, 1)
  taskScore      Decimal? @map("task_score") @db.Decimal(3, 1)
  actionScore    Decimal? @map("action_score") @db.Decimal(3, 1)
  resultScore    Decimal? @map("result_score") @db.Decimal(3, 1)
  overallScore   Decimal? @map("overall_score") @db.Decimal(3, 1)
  feedback       String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("topic_scores")
}

model Feedback {
  id             String   @id @default(uuid()) @db.Uuid
  interviewId    String   @unique @map("interview_id") @db.Uuid
  summary        String   @db.Text
  strengths      String[]
  improvements   String[]
  overallRating   String   @map("overall_rating") @db.VarChar(20)
  detailedReport  Json?    @map("detailed_report")
  techProficiency Json?    @map("tech_proficiency")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("feedback")
}
